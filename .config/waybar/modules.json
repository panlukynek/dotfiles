"wireplumber": {
    "format": "{volume}% {icon}",
    "format-muted": "",
    "on-click": "mute",
    "format-icons": ["", "", ""]
},
"mpris": {
  "format": "{player_icon} {dynamic}",
  "format-paused": "{status_icon} {dynamic}",
  "player-icons": {
    "default": "▶",
    "spotify": "🎵",
    "firefox": "🦊"
  },
  "status-icons": {
    "paused": "⏸"
  }
}